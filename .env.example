# DATABASE_* / ENCRYPTION_PASSPHRASE: stesse variabili documentate in
# www/SismaFramework/.env.example (lette via getenv() dal framework).
# DB_ROOT_PASSWORD: solo per il container MariaDB/phpMyAdmin, non usata da PHP.
DB_ROOT_PASSWORD=change_me_root_password
DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_NAME=skeletron_nginx
DATABASE_USERNAME=db_user
DATABASE_PASSWORD=change_me_db_password
ENCRYPTION_PASSPHRASE=change_me_encryption_passphrase

# MAIL_*: lette via getenv() dall'applicativo (client SMTP, es. PHPMailer).
# In sviluppo puntano al mock SMTP Mailpit (docker-compose.dev.yml, nessuna
# autenticazione/cifratura). In produzione sostituire con le credenziali del
# provider SMTP reale: cambiando solo questi valori nel .env non serve
# toccare il codice.
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_ENCRYPTION=none
MAIL_USERNAME=
MAIL_PASSWORD=

# BACKUP_*: usate dal servizio opzionale docker-compose.backup.yml (dump
# schedulato del database + pulizia dei dump più vecchi della retention).
# Il servizio parte solo se incluso esplicitamente nel comando compose.
BACKUP_SCHEDULE=0 3 * * *
BACKUP_RETENTION_DAYS=7
